generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  service     String
  preferredAt DateTime
  message     String?
  createdAt   DateTime @default(now())
}
